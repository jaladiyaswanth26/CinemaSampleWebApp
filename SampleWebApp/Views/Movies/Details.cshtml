@model Movie
@{
    ViewData["Title"] = Model.Title;
}

<div class="row">
    <div class="col-md-4">
        <img src="@Model.PosterUrl" class="img-fluid rounded" alt="@Model.Title">
    </div>
    <div class="col-md-8">
        <h2>@Model.Title</h2>
        <p><strong>Genre:</strong> @Model.Genre</p>
        <p><strong>Rating:</strong> ⭐ @Model.Rating</p>
        <p><strong>Description:</strong> @Model.Description</p>
        <p><strong>Showtimes:</strong></p>
        <ul>
            @foreach (var time in Model.Showtimes)
            {
                <li>@time</li>
            }
        </ul>
        <a asp-action="Book" asp-route-id="@Model.Id" class="btn btn-success btn-lg">Book Now</a>
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </div>
</div>